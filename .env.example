# Copia este archivo a ".env" y pon tu API key real.
# Consíguela gratis (500 req/mes) en: https://the-odds-api.com/

# Tu API key de The Odds API. Si la dejas vacía, la plataforma corre en MODO DEMO.
ODDS_API_KEY=

# Región de las casas de apuestas: us, us2, uk, eu, au
# "us" y "eu" suelen traer buena cobertura de fútbol y deportes de EE.UU.
ODDS_REGIONS=us,eu

# Formato de cuota: decimal (recomendado, es el que usa Caliente) o american
ODDS_FORMAT=decimal

# Fracción de Kelly para el sizing (0.25 = cuarto de Kelly, conservador y recomendado)
KELLY_FRACTION=0.25

# Bankroll actual en pesos (para calcular cuánto apostar)
BANKROLL=100

# Value mínimo (edge) para considerar una apuesta, en % (ej. 2.0 = 2%)
MIN_EDGE=2.0

# Apuesta mínima real en pesos (lo que acepta la casa; Caliente ~10)
MIN_STAKE=10

# Tope de seguridad: nunca apostar más de este % del bankroll en una sola jugada
MAX_STAKE_PCT=15
